# העתק את הקובץ הזה לקובץ בשם .env.local ומלא את הערכים מ-Supabase.
# (פרטים מלאים במדריך ההתקנה, שלב 4)

VITE_SUPABASE_URL=כאן_מדביקים_את_הכתובת
VITE_SUPABASE_ANON_KEY=כאן_מדביקים_את_המפתח

# מפתח YouTube Data API v3 (לייבוא סרטונים אוטומטי) — רשות.
# https://console.cloud.google.com → הפעל את ה-API → צור API key.
# חובה: הגבל את המפתח ל-HTTP referrers של הדומיין שלך!
VITE_YOUTUBE_API_KEY=
